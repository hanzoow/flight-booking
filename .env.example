# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# On Vercel: do NOT upload this file. Add the same variables in:
#   Project → Settings → Environment Variables
#   (Production + Preview; use "Sensitive" for the token.)

# Required — Duffel API (server-only; never NEXT_PUBLIC_*)
DUFFEL_ACCESS_TOKEN=

# Optional — hide Duffel test card hints on payment page in production UI
# NEXT_PUBLIC_SHOW_DUFFEL_TEST_CARDS=false

# Optional — server-only debug: log full Duffel offer JSON to the terminal when calling /api/offer-requests
# DEBUG_DUFFEL_OFFERS=1        # only offers[]
# DEBUG_DUFFEL_OFFERS=all      # entire offer_request payload
